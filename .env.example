# URL completo del progetto Supabase, es. https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Anon key Supabase valida
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Base URL dell'app usata per i redirect email del reset password
NEXT_PUBLIC_APP_BASE_URL=http://localhost:3000
APP_BASE_URL=

# API key del provider esterno per generare file .pkpass lato server.
# Non esporla mai nel client.
WALLETWALLET_API_KEY=
WALLETWALLET_ENABLE_PRO_ASSETS=true
